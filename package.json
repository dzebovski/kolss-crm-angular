{
  "name": "kolss-crm-angular",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "prestart": "node scripts/sync-env.mjs",
    "start": "ng serve",
    "prebuild": "node scripts/sync-env.mjs --prod",
    "build": "ng build",
    "prewatch": "node scripts/sync-env.mjs",
    "watch": "ng build --watch --configuration development",
    "sync-env": "node scripts/sync-env.mjs",
    "sync-env:prod": "node scripts/sync-env.mjs --prod",
    "test": "ng test",
    "lint": "ng lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check:api-boundary": "node scripts/check-api-boundary.mjs",
    "check": "npm run check:api-boundary && npx tsc -p tsconfig.app.json --noEmit && npm run lint && npm test",
    "functions:deploy": "npx supabase functions deploy site-lead --no-verify-jwt && npx supabase functions deploy process-notifications --no-verify-jwt && npx supabase functions deploy admin-users",
    "functions:deploy:webhooks": "npx supabase functions deploy site-lead --no-verify-jwt && npx supabase functions deploy process-notifications --no-verify-jwt",
    "functions:deploy:admin": "npx supabase functions deploy admin-users",
    "functions:smoke": "bash scripts/smoke-edge-functions.sh"
  },
  "private": true,
  "engines": {
    "node": "24.x"
  },
  "packageManager": "npm@11.17.0",
  "dependencies": {
    "@angular/aria": "^22.0.2",
    "@angular/cdk": "^22.0.2",
    "@angular/common": "^22.0.5",
    "@angular/compiler": "^22.0.5",
    "@angular/core": "^22.0.5",
    "@angular/forms": "^22.0.5",
    "@angular/material": "^22.0.2",
    "@angular/platform-browser": "^22.0.5",
    "@angular/router": "^22.0.5",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/inter-tight": "^5.2.7",
    "@supabase/supabase-js": "^2.110.1",
    "@vercel/analytics": "^2.0.1",
    "axe-core": "^4.12.1",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^22.0.5",
    "@angular/cli": "^22.0.5",
    "@angular/compiler-cli": "^22.0.5",
    "@eslint/js": "^10.0.1",
    "@material-symbols/svg-400": "^0.45.5",
    "angular-eslint": "22.0.0",
    "eslint": "^10.3.0",
    "jsdom": "^28.0.0",
    "prettier": "^3.8.1",
    "typescript": "~6.0.3",
    "typescript-eslint": "8.60.1",
    "vitest": "^4.0.8"
  }
}
