# Public keys only — safe for the Angular frontend / Vercel build.
# scripts/sync-env.mjs accepts SUPABASE_* or NEXT_PUBLIC_SUPABASE_* names.

# Required for production build (Vercel → Environment Variables)
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Optional — defaults to https://$VERCEL_URL on Vercel
SITE_URL=http://localhost:4200
SITE_URL_PUBLIC=http://localhost:4200
